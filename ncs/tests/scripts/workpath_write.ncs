// ============================================================
// Test: workpath_write.ncs
// Purpose: WorkPath + Write + Read combined workflow.
//   - Set work path to temp dir
//   - Write a new config file
//   - Read it back to verify
// ============================================================

// -- Step 1: Set work path to the test data directory --
!@WorkPath ./tests/data

// -- Step 2: Write a new config file --
!@Write Normal _ncs_generated_config.toml
# Auto-generated by NCS integration test

[server]
host = "0.0.0.0"
port = 8080

[database]
url = "postgres://localhost:5432/ncs_test"
@/Write

// -- Step 3: Read the file back with syntax highlighting --
!@Read _ncs_generated_config.toml start=1 end=5

// -- Step 4: Write another file --
!@Write Normal _ncs_notes.txt
NCS integration test notes.
Test executed successfully.
@/Write

// -- Step 5: Read the second file --
!@Read _ncs_notes.txt
