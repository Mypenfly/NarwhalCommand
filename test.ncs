!@Open ./lexer.rs

!@Location
pub enum Token {
	!@Location
	Close {
        /// 关闭的命令名
        name: String,
        /// 所在行号
        line: LineNumber,
		
		!@Delete
        /// Capture 管道: @/Open | Capture pool_name
        capture: Option<String>,
		!@New
		/// 测试用
		test:String,
	@/Location
@/Location

!@Location
impl Lexer {
	!@Location Block
    /// 为 Command Token 设置 content_lines
    fn set_content_lines(token: Token, content_lines: Vec<String>) -> Token {
	!@Delete Block
	@/Location
@/Location

@/Open
	
		
		
